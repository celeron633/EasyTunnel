# EasyTunnel IPv4 NAT traversal client

# Public IPv4 rendezvous service deployed with EasyTunnel_rendezvous.
rendezvous_addr=203.0.113.10
rendezvous_port=3478

# Both peers use the same room_id and auth_token, but different peer_id values.
room_id=example-room
peer_id=node-a
# Empty: register and wait for another client to select this node.
# Set to a peer ID (for example node-b): actively connect to that node.
target_peer_id=
auth_token=change-this-secret

# Send direct peer traffic often enough to retain port-restricted/CGN mappings.
keepalive_interval=15
peer_timeout=45
# Send one 1024-byte peer-only padding packet per second. Enable on both peers
# for approximately 1 KiB/s in each direction. Padding never enters the TUN,
# but is included in the client traffic statistics.
dummy_traffic_enabled=false
punch_timeout=30

# Ordered traversal strategy. Every mode must appear exactly once; use true or
# false to enable or disable it. Both peers should use the same enabled order.
# Available modes: nat, nat4, ipv6, ipv4_relay.
traversal_modes=nat:true,nat4:true,ipv6:false,ipv4_relay:false

# NAT4 binds a consecutive UDP socket pool and predicts the peer's increasing
# public port. Disable it through traversal_modes rather than using a zero count.
nat4_source_port_start=30000
nat4_source_port_count=25
nat4_peer_port_offset=20
nat4_round_timeout=10

# IPv6 direct-connection parameters. Both peers must enable this mode. At least
# one peer must accept unsolicited inbound
# IPv6 UDP; port 0 asks the OS to choose the local data port.
ipv6_accept_inbound=false
ipv6_listen_port=0
# TCP endpoint used to verify IPv6 Internet reachability and select the GUA.
# An IPv6 literal (without brackets) or an AAAA-capable hostname is accepted.
ipv6_probe_host=2400:3200::1
ipv6_probe_port=53
ipv6_fallback_timeout=15

# The ipv4_relay mode additionally requires relay support on both peers and the
# rendezvous server.

adapter_name=EasyTunnel
local_tun_ipv4=10.66.0.1
tun_prefix=24
tun_mtu=1452
auto_config_ipv4=true
log_level=Info
