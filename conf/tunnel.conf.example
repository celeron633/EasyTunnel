# 6Tunnel config (key=value)
# Required:
#   local_addr     : optional local bind IP; leave empty to bind any address
#   peer_addr      : peer public IPv4 or IPv6
#   local_tun_ipv4 : local Wintun interface IPv4
# Legacy local_ipv6/peer_ipv6 keys are still accepted.

local_addr=::
peer_addr=2001:db8:1::20
# peer_addr=198.51.100.20
udp_port=44556

adapter_name=6Tunnel
# Optional tunnel type label for Wintun
# tunnel_type=6Tunnel

local_tun_ipv4=10.66.0.1
tun_prefix=24
tun_mtu=1452

auto_config_ipv4=true
log_level=Info
